<launch>
    <node name="rvizvisualisation" pkg="rviz" type="rviz" output="log" 
        args="-d $(find vins)/../config/vins_rviz_high.rviz" />
    <node name="vins_estimator" pkg="vins" type="vins_node" output="screen" 
        args="$(find vins)/../config/high_altitude/high_stereo_imu_config.yaml" />
    <node name="loop_fusion" pkg="loop_fusion" type="loop_fusion_node" 
        output="screen" args="$(find vins)/../config/high_altitude/high_stereo_imu_config.yaml" />
</launch>

